@page "/library"
@using BookNetApp.Shared
@using BookNetApp.Client.Services
@inject HttpClient Http
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation

<PageTitle>BookNet — Моя библиотека</PageTitle>

<div class="container mt-4 text-light position-relative">
    
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-secondary pb-3">
        <h4 class="fw-bold mb-0 text-light text-uppercase">📚 Моя Библиотека</h4>
        <button class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm d-flex align-items-center gap-2" @onclick="OpenModal">
            <span>➕</span> Добавить книгу
        </button>
    </div>

    @if (isModalOpen)
    {
        <div class="modal-backdrop-custom">
            <div class="card p-4 border-0 shadow-lg animate-modal" style="background-color: #16161a; width: 100%; max-width: 800px; border: 1px solid #24242b !important;">
                
                <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-secondary pb-2">
                    <h5 class="fw-bold text-info mb-0">🛠 Добавление книги в библиотеку</h5>
                    <button class="btn-close-custom" @onclick="CloseModal">&times;</button>
                </div>

                @if (!string.IsNullOrEmpty(serverErrorMessage))
                {
                    <div class="alert alert-danger py-2 small fw-bold mb-3">⚠️ @serverErrorMessage</div>
                }

                <div class="row">
                    <div class="col-md-6 border-end border-secondary p-md-3 mb-4 mb-md-0 text-start">
                        <h6 class="fw-bold text-secondary small text-uppercase mb-3">📌 Найти существующую в базе:</h6>
                        
                        <div class="mb-3">
                            <label class="form-label small text-muted">Быстрый поиск по названию или автору:</label>
                            <input type="text" class="form-control form-control-sm bg-dark text-light border-secondary ps-3"
                                   @bind="bookSearchQuery" @bind:event="oninput" placeholder="Начните писать..." />
                        </div>

                        <div class="mb-3">
                            <label class="form-label small text-muted">Выберите результат поиска:</label>
                            <select class="form-select bg-dark text-light border-secondary" @bind="selectedExistingBookId">
                                <option value="0">-- Найдено книг: @(FilteredGlobalBooks?.Count ?? 0) --</option>
                                @if (FilteredGlobalBooks != null)
                                {
                                    @foreach (var globalBook in FilteredGlobalBooks)
                                    {
                                        <option value="@globalBook.Id">@globalBook.Title — @globalBook.Author</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small text-muted">На какую полку поставить?</label>
                            <select class="form-select bg-dark text-light border-secondary" @bind="existingBookStatus">
                                <option value="@BookStatus.Reading">📖 Читаю</option>
                                <option value="@BookStatus.PlanToRead">⏳ В планах</option>
                                <option value="@BookStatus.Finished">✅ Прочитано</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small text-muted">Ваш отзыв / заметка:</label>
                            <textarea class="form-control bg-dark text-light border-secondary" @bind="existingBookComment" placeholder="Что думаете о книге..." rows="2"></textarea>
                        </div>

                        <div class="text-end mt-3">
                            <button class="btn btn-info rounded-pill px-4 fw-bold text-dark w-100 shadow-sm" @onclick="AddExistingBook" disabled="@(selectedExistingBookId == 0)">Добавить на полку</button>
                        </div>
                    </div>

                    <div class="col-md-6 p-md-3 ps-md-4 text-start">
                        <h6 class="fw-bold text-secondary small text-uppercase mb-3">✨ Создать новую с обложкой:</h6>
                        
                        <div class="mb-2">
                            <label class="form-label small text-muted">Название:</label>
                            <input type="text" class="form-control bg-dark text-light border-secondary" @bind="newBook.Title" placeholder="Название книги" />
                        </div>
                        
                        <div class="mb-2">
                            <label class="form-label small text-muted">Автор:</label>
                            <input type="text" class="form-control bg-dark text-light border-secondary" @bind="newBook.Author" placeholder="Автор" />
                        </div>

                        <div class="mb-2">
                            <label class="form-label small text-muted">Ссылка на обложку (URL):</label>
                            <input type="text" class="form-control bg-dark text-light border-secondary" @bind="newBook.CoverUrl" placeholder="URL картинки из интернета" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label small text-muted">Статус и отзыв:</label>
                            <select class="form-select bg-dark text-light border-secondary mb-2" @bind="newBook.Status">
                                <option value="@BookStatus.Reading">📖 Читаю</option>
                                <option value="@BookStatus.PlanToRead">⏳ В планах</option>
                                <option value="@BookStatus.Finished">✅ Прочитано</option>
                            </select>
                            <textarea class="form-control bg-dark text-light border-secondary" @bind="newBook.UserComment" placeholder="Ваш краткий отзыв..." rows="2"></textarea>
                        </div>

                        <div class="text-end mt-3">
                            <button class="btn btn-success rounded-pill px-4 fw-bold w-100 shadow-sm" @onclick="AddNewBook">Создать и добавить</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="row">
        @foreach (var status in Enum.GetValues(typeof(BookStatus)).Cast<BookStatus>())
        {
            <div class="col-md-4 mb-4">
                <div class="p-3 rounded-4 drop-zone"
                     style="background-color: #16161a; min-height: 500px; border: 1px solid #24242b; box-shadow: 0 4px 20px rgba(0,0,0,0.2);"
                     ondragover="event.preventDefault();"
                     @ondrop="() => HandleDrop(status)">
                    
                    <h6 class="fw-bold text-uppercase text-center p-2 rounded-3 text-white mb-3 @GetStatusBg(status)">
                        @GetStatusLabel(status)
                    </h6>
                    
                    <div class="book-list">
                        @if (userBooks != null && userBooks.Any(b => b.Status == status))
                        {
                            @foreach (var book in userBooks.Where(b => b.Status == status))
                            {
                                <div class="p-2 mb-3 border-0 position-relative d-flex align-items-center book-card"
                                     draggable="true"
                                     @ondragstart="() => HandleDragStart(book)"
                                     style="cursor: grab; gap: 12px; border-radius: 10px; background-color: #1c1c22; border: 1px solid #24242b; transition: transform 0.2s, border-color 0.2s;">
                                    
                                    <img src="@(string.IsNullOrEmpty(book.CoverUrl) ? "https://unsplash.com" : book.CoverUrl)"
                                         alt="Обложка" class="shadow-sm rounded" style="width: 45px; height: 65px; object-fit: cover; flex-shrink: 0;"
                                         onerror="this.src='https://unsplash.com';" />

                                    <div class="overflow-hidden flex-grow-1 text-start pe-4">
                                        <div class="fw-bold text-light text-truncate" style="font-size: 0.9rem;">@book.Title</div>
                                        <div class="text-muted text-truncate" style="font-size: 0.75rem;">@book.Author</div>
                                    </div>
                                    
                                    <button class="btn btn-sm text-danger position-absolute top-0 end-0 m-1 border-0 bg-transparent fw-bold"
                                            style="font-size: 1.1rem; line-height: 1;" @onclick="() => DeleteBook(book.Id)">
                                        &times;
                                    </button>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center text-muted small py-5 opacity-25">Перетащите книги сюда ЛКМ</div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .modal-backdrop-custom {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(0, 0, 0, 0.85);
        backdrop-filter: blur(8px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1050;
        padding: 20px;
    }

    .btn-close-custom {
        background: none;
        border: none;
        font-size: 2rem;
        line-height: 1;
        color: #aaa;
        cursor: pointer;
        transition: color 0.2s;
        padding: 0;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
    }

        .btn-close-custom:hover {
            color: #fff;
            background-color: rgba(255, 255, 255, 0.1);
        }

    .animate-modal {
        animation: modalSlideIn 0.3s ease-out;
    }

    @@keyframes modalSlideIn {
        from {
            opacity: 0;
            transform: translateY(-50px) scale(0.95);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .book-card:active {
        cursor: grabbing;
        opacity: 0.6;
        transform: scale(0.97);
    }
    
    .book-card:hover {
        border-color: #388bfd !important;
        background-color: #22222a !important;
        transform: translateY(-2px);
    }

    .drop-zone {
        transition: all 0.2s ease;
    }

        .drop-zone:hover {
            border-color: #388bfd !important;
        }
</style>

@code {
    private List<Book>? userBooks;
    private List<Book>? allGlobalBooks;
    private Book newBook = new Book { Status = BookStatus.Reading };
    private Book? draggingBook;
    private string serverErrorMessage = "";
    private bool isModalOpen = false;

    private string bookSearchQuery = "";
    private int selectedExistingBookId = 0;
    private BookStatus existingBookStatus = BookStatus.Reading;
    private string existingBookComment = "";

    private List<Book>? FilteredGlobalBooks =>
        string.IsNullOrWhiteSpace(bookSearchQuery)
            ? allGlobalBooks
            : allGlobalBooks?.Where(b =>
                b.Title.ToLower().Contains(bookSearchQuery.ToLower()) ||
                b.Author.ToLower().Contains(bookSearchQuery.ToLower())
              ).ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadLibrary();
    }

    private async Task LoadLibrary()
    {
        try
        {
            var user = await Http.GetFromJsonAsync<User>("api/auth/me");
            if (user != null)
            {
                userBooks = await Http.GetFromJsonAsync<List<Book>>($"api/book/user/{user.Id}");
            }
            allGlobalBooks = await Http.GetFromJsonAsync<List<Book>>("api/book");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки данных: {ex.Message}");
        }
    }

    private void OpenModal() => isModalOpen = true;

    private void CloseModal()
    {
        isModalOpen = false;
        serverErrorMessage = "";
        bookSearchQuery = "";
        selectedExistingBookId = 0;
        existingBookComment = "";
    }

    private async Task AddExistingBook()
    {
        if (selectedExistingBookId == 0) return;
        serverErrorMessage = "";
        
        var selectedBook = allGlobalBooks?.FirstOrDefault(b => b.Id == selectedExistingBookId);
        if (selectedBook == null) return;
        
        var bookCopyToAssign = new Book
        {
            Title = selectedBook.Title,
            Author = selectedBook.Author,
            CoverUrl = selectedBook.CoverUrl,
            Status = existingBookStatus,
            UserComment = existingBookComment
        };
        
        try
        {
            var response = await Http.PostAsJsonAsync("api/book", bookCopyToAssign);
            if (response.IsSuccessStatusCode)
            {
                selectedExistingBookId = 0;
                existingBookComment = "";
                CloseModal();
                await LoadLibrary();
            }
            else
            {
                serverErrorMessage = await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            serverErrorMessage = ex.Message;
        }
    }

    private async Task AddNewBook()
    {
        if (string.IsNullOrWhiteSpace(newBook.Title) || string.IsNullOrWhiteSpace(newBook.Author))
            return;
        
        serverErrorMessage = "";
        
        try
        {
            var response = await Http.PostAsJsonAsync("api/book", newBook);
            if (response.IsSuccessStatusCode)
            {
                newBook = new Book { Status = BookStatus.Reading };
                CloseModal();
                await LoadLibrary();
            }
            else
            {
                serverErrorMessage = await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            serverErrorMessage = ex.Message;
        }
    }

    private async Task DeleteBook(int bookId)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/book/{bookId}");
            if (response.IsSuccessStatusCode)
                await LoadLibrary();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }

    private void HandleDragStart(Book book) => draggingBook = book;

    private async Task HandleDrop(BookStatus newStatus)
    {
        if (draggingBook != null && draggingBook.Status != newStatus)
        {
            draggingBook.Status = newStatus;
            try
            {
                var response = await Http.PutAsJsonAsync($"api/book/update-status/{draggingBook.Id}", newStatus);
                if (response.IsSuccessStatusCode)
                    await LoadLibrary();
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
            }
        }
        draggingBook = null;
    }

    private string GetStatusLabel(BookStatus status) => status switch
    {
        BookStatus.Reading => "📖 Читаю",
        BookStatus.PlanToRead => "⏳ В планах",
        BookStatus.Finished => "✅ Прочитано",
        _ => ""
    };

    private string GetStatusBg(BookStatus status) => status switch
    {
        BookStatus.Reading => "bg-primary text-white",
        BookStatus.PlanToRead => "bg-warning text-dark",
        BookStatus.Finished => "bg-success text-white",
        _ => "bg-secondary text-white"
    };
}