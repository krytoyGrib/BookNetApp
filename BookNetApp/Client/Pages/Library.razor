@page "/library"
@using BookNetApp.Shared
@using BookNetApp.Client.Services
@inject HttpClient Http
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation

<PageTitle>BookNet — Моя библиотека</PageTitle>

<div class="container mt-4 text-light">
    <div class="card p-4 border-0 shadow mb-4" style="background-color: #16161a; border-radius: 16px;">
        <h5 class="fw-bold text-info mb-4 border-bottom border-secondary pb-2">➕ Добавить книгу на свою полку</h5>
        
        @if (!string.IsNullOrEmpty(serverErrorMessage))
        {
            <div class="alert alert-danger py-2 small fw-bold mb-3">⚠️ @serverErrorMessage</div>
        }

        <div class="row g-3">
            <div class="col-md-4">
                <input type="text" class="form-control bg-dark text-light border-secondary" @bind="newBook.Title" placeholder="Название книги" />
            </div>
            <div class="col-md-4">
                <input type="text" class="form-control bg-dark text-light border-secondary" @bind="newBook.Author" placeholder="Автор" />
            </div>
            <div class="col-md-4">
                <select class="form-select bg-dark text-light border-secondary" @bind="newBook.Status">
                    <option value="@BookStatus.Reading">📖 Читаю</option>
                    <option value="@BookStatus.PlanToRead">⏳ В планах</option>
                    <option value="@BookStatus.Finished">✅ Прочитано</option>
                </select>
            </div>
            <div class="col-12">
                <input type="text" class="form-control bg-dark text-light border-secondary" @bind="newBook.CoverUrl" placeholder="Ссылка на обложку (URL картинки из интернета)" />
            </div>
            <div class="col-12">
                <textarea class="form-control bg-dark text-light border-secondary" @bind="newBook.UserComment" placeholder="Ваш краткий отзыв или заметка..." rows="2"></textarea>
            </div>
            <div class="col-12 text-end">
                <button class="btn btn-primary rounded-pill px-5 fw-bold shadow-sm" @onclick="AddNewBook">Сохранить книгу</button>
            </div>
        </div>
    </div>

    <div class="row">
        @foreach (var status in Enum.GetValues(typeof(BookStatus)).Cast<BookStatus>())
        {
            <div class="col-md-4 mb-4">
                <div class="p-3 rounded-4 drop-zone" 
                     style="background-color: #16161a; min-height: 450px; border: 2px dashed #24242b;"
                     ondragover="event.preventDefault();"
                     @ondrop="() => HandleDrop(status)">
                    
                    <h6 class="fw-bold text-uppercase text-center p-2 rounded-3 text-white mb-3 @GetStatusBg(status)">
                        @GetStatusLabel(status)
                    </h6>
                    
                    <div class="book-list">
                        @if (userBooks != null && userBooks.Any(b => b.Status == status))
                        {
                            @foreach (var book in userBooks.Where(b => b.Status == status))
                            {
                                <div class="p-2 mb-3 border-0 position-relative d-flex align-items-center book-card"
                                     draggable="true"
                                     @ondragstart="() => HandleDragStart(book)"
                                     style="cursor: grab; gap: 12px; border-radius: 10px; background-color: #1c1c22; border: 1px solid #24242b; transition: transform 0.2s;">
                                    
                                    <img src="@(string.IsNullOrEmpty(book.CoverUrl) ? "https://unsplash.com" : book.CoverUrl)" 
                                         alt="Обложка" class="shadow-sm rounded" style="width: 45px; height: 65px; object-fit: cover; flex-shrink: 0;"
                                         onerror="this.src='https://unsplash.com';" />

                                    <div class="overflow-hidden flex-grow-1 text-start pe-4">
                                        <div class="fw-bold text-light text-truncate" style="font-size: 0.9rem;">@book.Title</div>
                                        <div class="text-muted text-truncate" style="font-size: 0.75rem;">@book.Author</div>
                                    </div>
                                    
                                    <button class="btn btn-sm text-danger position-absolute top-0 end-0 m-1 border-0 bg-transparent fw-bold" 
                                            style="font-size: 1.1rem; line-height: 1;" @onclick="() => DeleteBook(book.Id)">
                                        &times;
                                    </button>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center text-muted small py-4 opacity-50">Перетащите книги зажав ЛКМ</div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .book-card:active { cursor: grabbing; opacity: 0.6; transform: scale(0.97); }
    .book-card:hover { border-color: #388bfd !important; background-color: #22222a !important; }
</style>

@code {
    private List<Book>? userBooks;
    private Book newBook = new Book { Status = BookStatus.Reading };
    private Book? draggingBook;
    private string serverErrorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadLibrary();
    }

    private async Task LoadLibrary()
    {
        try
        {
            var user = await Http.GetFromJsonAsync<User>("api/auth/me");
            if (user != null)
            {
                userBooks = await Http.GetFromJsonAsync<List<Book>>($"api/book/user/{user.Id}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки: {ex.Message}");
        }
    }

    private async Task AddNewBook()
    {
        if (string.IsNullOrWhiteSpace(newBook.Title) || string.IsNullOrWhiteSpace(newBook.Author)) return;
        serverErrorMessage = "";

        var response = await Http.PostAsJsonAsync("api/book", newBook);
        if (response.IsSuccessStatusCode)
        {
            newBook = new Book { Status = BookStatus.Reading };
            await LoadLibrary();
        }
        else
        {
            serverErrorMessage = await response.Content.ReadAsStringAsync();
        }
    }

    private async Task DeleteBook(int bookId)
    {
        var response = await Http.DeleteAsync($"api/book/{bookId}");
        if (response.IsSuccessStatusCode)
        {
            await LoadLibrary();
        }
    }

    private void HandleDragStart(Book book)
    {
        draggingBook = book;
    }

    private async Task HandleDrop(BookStatus newStatus)
    {
        if (draggingBook != null && draggingBook.Status != newStatus)
        {
            draggingBook.Status = newStatus;
            
            var response = await Http.PutAsJsonAsync($"api/book/update-status/{draggingBook.Id}", newStatus);
            if (response.IsSuccessStatusCode)
            {
                await LoadLibrary();
            }
        }
        draggingBook = null;
    }

    private string GetStatusLabel(BookStatus status) => status switch 
    { 
        BookStatus.Reading => "📖 Читаю", 
        BookStatus.PlanToRead => "⏳ В планах", 
        BookStatus.Finished => "✅ Прочитано", 
        _ => "" 
    };

    private string GetStatusBg(BookStatus status) => status switch 
    { 
        BookStatus.Reading => "bg-primary text-white", 
        BookStatus.PlanToRead => "bg-warning text-dark", 
        BookStatus.Finished => "bg-success text-white", 
        _ => "bg-secondary text-white" 
    };
}
