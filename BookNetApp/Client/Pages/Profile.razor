@page "/profile"
@page "/profile/{UserId:int}"
@using BookNetApp.Shared
@using System.Security.Claims
@inject HttpClient Http
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation

<PageTitle>BookNet — Профиль</PageTitle>

<div class="container mt-5 text-light">
    @if (user == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-info" style="width: 3rem; height: 3rem;" role="status"></div>
            <p class="mt-3 fw-bold text-muted fs-5">Загрузка профиля...</p>
        </div>
    }
    else
    {
        <div class="row justify-content-center">
            <div class="col-md-4 mb-4">
                <div class="card p-4 text-center border-0 shadow"
                     style="border-radius: 16px; background-color: #16161a; box-shadow: 0 8px 32px rgba(0,0,0,0.3) !important;">
                    
                    <div class="position-relative d-inline-block mx-auto mb-3">
                        <img src="@(string.IsNullOrEmpty(user.AvatarUrl) ? "default_avatar.png" : user.AvatarUrl)"
                             class="rounded-circle border border-2 border-info shadow-sm"
                             style="width: 150px; height: 150px; object-fit: cover;"
                             onerror="this.src='default_avatar.png';" />
                    </div>
                    
                    <h3 class="fw-bold mb-1 text-light">@user.Username</h3>
                    <p class="text-info small mb-3">@user.Email</p>
                    
                    <div class="p-3 rounded-4 mb-4 text-start" style="background-color: #1c1c22; border: 1px solid #24242b;">
                        <h6 class="fw-bold small text-uppercase text-muted mb-2 text-center border-bottom border-secondary pb-1">О себе</h6>
                        
                        @if (isEditing)
                        {
                            <label class="small text-muted mb-1">Ссылка на аватарку (URL):</label>
                            <input type="text" class="form-control form-control-sm mb-3 bg-dark text-light border-secondary"
                                   @bind="user.AvatarUrl" placeholder="Вставьте URL картинки из интернета" />

                            <label class="small text-muted mb-1">О себе:</label>
                            <textarea class="form-control mb-3 bg-dark text-light border-secondary fw-bold"
                                      @bind="user.Bio" placeholder="Расскажите о себе..." rows="3" style="border-radius: 8px;"></textarea>
                            
                            <div class="d-flex gap-2">
                                <button class="btn btn-success btn-sm flex-grow-1 fw-bold rounded-pill" @onclick="SaveProfile">Сохранить</button>
                                <button class="btn btn-secondary btn-sm fw-bold rounded-pill" @onclick="() => isEditing = false">Отмена</button>
                            </div>
                        }
                        else
                        {
                            <p class="mb-0 text-light text-center" style="font-size: 0.95rem;">
                                @(string.IsNullOrEmpty(user.Bio) ? "Пользователь еще ничего не рассказал о себе." : user.Bio)
                            </p>
                        }
                    </div>

                    @if (isMyProfile && !isEditing)
                    {
                        <button class="btn btn-outline-info w-100 fw-bold py-2 fs-6 rounded-pill shadow-sm" @onclick="() => isEditing = true">
                            ⚙️ Редактировать профиль
                        </button>
                    }
                    else if (!isMyProfile)
                    {
                        <a href="messages/@user.Id" class="btn btn-info w-100 fw-bold text-dark py-2 fs-6 rounded-pill shadow-sm">
                            ✉️ Написать сообщение
                        </a>
                    }
                </div>
            </div>

            <div class="col-md-8 mb-4">
                <div class="card p-4 border-0 shadow" style="background-color: #16161a; box-shadow: 0 8px 32px rgba(0,0,0,0.3) !important;">
                    <h4 class="fw-bold mb-4 text-light text-uppercase border-bottom border-secondary pb-2">📚 Книжная полка</h4>
                    <div class="row">
                        @foreach (var status in Enum.GetValues(typeof(BookStatus)).Cast<BookStatus>())
                        {
                            <div class="col-md-4 mb-4">
                                <h6 class="fw-bold text-uppercase text-center p-2 rounded-3 text-white @GetStatusBg(status)">
                                    @GetStatusLabel(status)
                                </h6>
                                <div class="mt-3">
                                    @if (userBooks != null && userBooks.Any(b => b.Status == status))
                                    {
                                        @foreach (var book in userBooks.Where(b => b.Status == status))
                                        {
                                            <div class="p-2 mb-3 border-0 position-relative d-flex align-items-center shadow-sm"
                                                 title="@book.UserComment"
                                                 style="border-radius: 10px; background-color: #1c1c22; border: 1px solid #24242b; gap: 10px;">
                                                
                                                <img src="@(string.IsNullOrEmpty(book.CoverUrl) ? "https://unsplash.com" : book.CoverUrl)"
                                                     alt="Обложка" class="rounded" style="width: 45px; height: 65px; object-fit: cover; flex-shrink: 0;"
                                                     onerror="this.src='https://unsplash.com';" />
                                                
                                                <div class="overflow-hidden flex-grow-1 text-start">
                                                    <div class="fw-bold text-light text-truncate" style="font-size: 0.9rem; line-height: 1.2;">@book.Title</div>
                                                    <div class="text-muted text-truncate mt-1" style="font-size: 0.75rem;">@book.Author</div>
                                                </div>

                                                @if (!string.IsNullOrEmpty(book.UserComment))
                                                {
                                                    <span class="position-absolute bottom-0 end-0 m-1" style="font-size: 1rem;">💬</span>
                                                }
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="text-center text-muted small py-3 rounded-3" style="border: 1px dashed #2d2d38; background-color: #0f0f12;">Пусто</div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int? UserId { get; set; }
    private User? user;
    private List<Book>? userBooks;
    private bool isMyProfile = false;
    private bool isEditing = false;
    private int currentUserId;

    protected override async Task OnParametersSetAsync() => await LoadProfile();

    private async Task LoadProfile()
    {
        try
        {
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            var myIdClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier) ?? authState.User.FindFirst("sub");
            if (myIdClaim != null) currentUserId = int.Parse(myIdClaim.Value);

            if (UserId == null || UserId == 0 || UserId == currentUserId)
            {
                user = await Http.GetFromJsonAsync<User>("api/auth/me");
                isMyProfile = true;
            }
            else
            {
                user = await Http.GetFromJsonAsync<User>($"api/auth/user/{UserId}");
                isMyProfile = false;
            }

            if (user != null)
            {
                userBooks = await Http.GetFromJsonAsync<List<Book>>($"api/book/user/{user.Id}");
            }
        }
        catch { Navigation.NavigateTo("/"); }
    }

    private async Task SaveProfile()
    {
        if (user == null) return;
        var response = await Http.PutAsJsonAsync("api/auth/update", user);
        if (response.IsSuccessStatusCode)
        {
            isEditing = false;
            await LoadProfile();
        }
    }

    private string GetStatusLabel(BookStatus status) => status switch
    {
        BookStatus.Reading => "📖 Читаю",
        BookStatus.PlanToRead => "⏳ В планах",
        BookStatus.Finished => "✅ Прочитано",
        _ => ""
    };

    private string GetStatusBg(BookStatus status) => status switch
    {
        BookStatus.Reading => "bg-primary text-white",
        BookStatus.PlanToRead => "bg-warning text-dark",
        BookStatus.Finished => "bg-success text-white",
        _ => "bg-secondary text-white"
    };
}
